{
  "name": "@unity-explorer/mcp",
  "version": "0.1.0",
  "description": "MCP sidecar for UnityExplorer's local inspection bridge.",
  "type": "module",
  "bin": {
    "unity-explorer-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "USAGE.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node ./dist/index.js",
    "test:protocol": "node ./scripts/protocol-smoke-test.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "typescript": "^5.4.5"
  }
}
